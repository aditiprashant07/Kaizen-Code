[MASTER]
ignore=.venv,venv,env,.env,__pycache__,migrations
jobs=1

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    R0903   # too-few-public-methods

[FORMAT]
max-line-length=100
indent-string='    '

[DESIGN]
max-args=8
max-attributes=10

[SIMILARITIES]
min-similarity-lines=6
ignore-imports=yes
